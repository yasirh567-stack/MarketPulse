# Copy this file to `.env` and adjust as needed. Never commit the real `.env`.

# ---------------------------------------------------------------------------
# Core mode
# ---------------------------------------------------------------------------
# When true: no external API calls are made; all endpoints serve bundled
# fixtures from data/demo/. This is the recommended mode for recruiters/graders
# and requires zero API keys.
DEMO_MODE=true

ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite by default (file lives in backend/). Point this at a Postgres DSN
# (e.g. postgresql+psycopg://user:pass@host:5432/marketpulse) for production;
# no application code changes are required.
DATABASE_URL=sqlite:///./marketpulse.db

# ---------------------------------------------------------------------------
# Cache (optional Redis)
# ---------------------------------------------------------------------------
# Leave blank to use the built-in DB-backed TTL cache. Set to a redis:// URL to
# use Redis instead if you have one available locally.
REDIS_URL=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Data providers (all optional — the app works fully without any of these)
# ---------------------------------------------------------------------------
# Market data comes from yfinance (no key required) with automatic fallback to
# cached/demo data on rate limits or outages.
MARKET_DATA_PROVIDER=yfinance

# News comes from public Google News RSS (no key required).
NEWS_PROVIDER=rss

# Reddit social sentiment is OFF by default. To enable, create a free Reddit
# "script" app at https://www.reddit.com/prefs/apps and fill these in.
ENABLE_REDDIT=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=marketpulse-ai/0.1

# FinBERT is an optional, heavier NLP model (downloads ~440MB from Hugging
# Face on first use, requires torch+transformers). VADER is always available
# and is used automatically when this is false or when FinBERT fails to load.
ENABLE_FINBERT=false

# The Buffett Indicator (market-cap-to-GDP) widget is OFF by default and
# falls back to a clearly-labeled demo series. To enable it with real data,
# register a free API key at https://fred.stlouisfed.org/docs/api/api_key.html
ENABLE_FRED=false
FRED_API_KEY=

# ---------------------------------------------------------------------------
# WebSocket / polling
# ---------------------------------------------------------------------------
# Seconds between simulated/real market pushes over the WebSocket. Free data
# sources do not support sub-second ticks, so this is intentionally coarse.
MARKET_POLL_INTERVAL_SECONDS=15

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=120

# ---------------------------------------------------------------------------
# Frontend (Vite exposes only VITE_ prefixed vars to the browser)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_DEMO_MODE=true
